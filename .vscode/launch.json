{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CFLS Extension — alice",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension",
        "${workspaceFolder}/playground/alice"
      ],
      "outFiles": ["${workspaceFolder}/apps/vscode-extension/dist/**/*.js"]
    },
