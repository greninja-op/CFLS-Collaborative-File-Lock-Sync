{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CFLS Extension — alice",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension",
        "--user-data-dir=${workspaceFolder}/playground/.vscode-user-alice",
        "${workspaceFolder}/playground/alice"
      ],
      "outFiles": ["${workspaceFolder}/apps/vscode-extension/dist/**/*.js"]
    },
    {
      "name": "Run CFLS Extension — bob",
      "type": "extensionHost",
      "request": "launch",
