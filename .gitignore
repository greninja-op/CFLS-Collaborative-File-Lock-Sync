# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
*.tsbuildinfo

# Env & secrets
.env
.env.*
*.pem
*.key
*.crt

# Logs & caches
*.log
.cache/
coverage/
__pycache__/

# OS / editor
.DS_Store
Thumbs.db

# Local coordination data / sqlite
*.sqlite
*.sqlite3
*.db

# Interactive playground working dirs (generated by `pnpm playground`)
playground/

# Per-machine cfls onboarding secrets/config (never commit)
.cfls/

# Runtime coordination files written by `cfls agent` (per-machine, not shared)
.coordination/local-api.json
.coordination/agent.json
.coordination/.cache/

# Packaged VSIX build artifacts
apps/vscode-extension/vsix-pkg/dist/
apps/vscode-extension/vsix-pkg/*.vsix

# Standalone cfls.exe build intermediates (regenerate: pnpm -C apps/cli package:win)
apps/cli/dist-exe/

# The 89 MB standalone exe is NOT committed to git (it would bloat history
# permanently). It is regenerated from source or shipped via a GitHub Release.
release/*.exe
