# Copy to deploy/host/.env before starting the Host. Do not commit .env.
CFLS_TEAM_ID=cyberkunju-cfls
CFLS_REPO_ID=github.com/greninja-op/CFLS-Collaborative-File-Lock-Sync
CFLS_BRANCH=main
# Must match `git rev-parse HEAD` in the clone teammates use.
CFLS_BASE_REVISION=replace-with-the-deployed-commit
# Optional: enables the bearer-protected, read-only hosted MCP endpoint at
# https://sync.cfls.cyberkunju.com/mcp. Generate a high-entropy value on the
# server; never commit a real token.
CFLS_REMOTE_MCP_TOKEN=
CFLS_PUBLIC_RELAY_URL=wss://sync.cfls.cyberkunju.com
# Demo-only: lets the VS Code extension create/redeem 8-digit pairing codes.
# Never turn this on for a production relay.
CFLS_DEMO_OPEN_PAIRING=false
